---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentBlock from "../components/ContentBlock.astro";

const metaTitle = "404";
const metaDescription =
  "Oops! The page you're looking for doesn't exist. Head back to Dalton's homepage to explore projects and blog posts.";
---

<BaseLayout metaTitle={metaTitle} metaDescription={metaDescription}>
  <ContentBlock>
    <h1 class="text-3xl font-bold text-white text-center">
      404 - Page Not Found
    </h1>
  </ContentBlock>
</BaseLayout>
