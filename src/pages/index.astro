---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentBlock from "../components/ContentBlock.astro";

const metaTitle = "Home";
const metaDescription =
  "Discover Dalton's personal website featuring projects, blog posts, and insights on technology, creativity, and continuous learning.";
---

<BaseLayout metaTitle={metaTitle} metaDescription={metaDescription}>
  <ContentBlock command="$ whoami">
    <h1 class="text-3xl font-bold text-white">Hi there! I'm Dalton.</h1>
  </ContentBlock>

  <ContentBlock command="$ cat intro.txt">
    <p>Developer. Builder. Thinker.</p>

    <p>
      Welcome to my corner of the internet - a place for my projects, thoughts,
      and things I'm working on.
    </p>
  </ContentBlock>
</BaseLayout>
