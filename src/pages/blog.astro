---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentBlock from "../components/ContentBlock.astro";

const metaTitle = "Blog";
const metaDescription = "The blog page of Dalton's personal website.";

const allPosts = Object.values(
  import.meta.glob("./blog/*.{md,mdx}", { eager: true }),
);
---

<BaseLayout metaTitle={metaTitle} metaDescription={metaDescription}>
  <ContentBlock command="$ ls ~/blog">
    <h1 class="text-3xl font-bold text-white">Blog</h1>

    <ul class="flex flex-col gap-4">
      {
        allPosts.map((post: any) => (
          <li>
            <a href={post.url} class="group">
              <article class="flex flex-col border-gray-500/50 border p-6 gap-4 justify-between transition-colors ease-linear duration-300 group-hover:border-gray-500 md:flex-row">
                <div class="flex flex-col gap-2">
                  <h2 class="text-xl text-white">{post.frontmatter.title}</h2>
                  <p class="text-gray-400">{post.frontmatter.description}</p>
                </div>

                <time
                  datetime={post.frontmatter.publicationDate}
                  class="text-gray-400"
                >
                  {post.frontmatter.publicationDate}
                </time>
              </article>
            </a>
          </li>
        ))
      }
    </ul>
  </ContentBlock>
</BaseLayout>
