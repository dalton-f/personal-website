---
import BaseLayout from "./BaseLayout.astro";
import ContentBlock from "../components/ContentBlock.astro";

const { frontmatter } = Astro.props;
---

<BaseLayout metaTitle={frontmatter.title}>
  <ContentBlock command={`$ cat ..${frontmatter.url}/README.md`}>
    <article
      class="prose prose-h1:text-3xl prose-h1:m-0 prose-invert max-w-none md:prose-lg"
    >
      <div class="flex flex-col justify-between md:flex-row md:items-center">
        <h1 class="font-bold">{frontmatter.title}</h1>

        <p class="text-gray-400">
          {frontmatter.publicationDate.toString().slice(0, 10)}
        </p>
      </div>

      <slot />
    </article>
  </ContentBlock>
</BaseLayout>
